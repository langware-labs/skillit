{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/exec-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/pre_tool_ensure_flowpad_is_installed.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/exec-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/bin/call-flow-cli.py\" \"report\" \"hooks\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/exec-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/bin/call-flow-cli.py\" \"report\" \"hooks\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "skillit:skillit-creator",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/exec-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/bin/call-flow-cli.py\" \"report\" \"hooks\""
          }
        ]
      }
    ]
  }
}

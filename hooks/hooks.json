{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cli-launcher\" \"${CLAUDE_PLUGIN_ROOT}/scripts/main.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cli-launcher\" \"${CLAUDE_PLUGIN_ROOT}/scripts/main.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "skillit:skillit-creator",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cli-launcher\" \"${CLAUDE_PLUGIN_ROOT}/scripts/main.py\""
          }
        ]
      }
    ]
  }
}
